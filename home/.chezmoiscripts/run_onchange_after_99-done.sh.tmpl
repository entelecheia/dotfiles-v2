#!/usr/bin/env bash
# ── Config hash (설정 변경 시 재실행) ──
# {{ .name }} {{ .email }} {{ .github_user }} {{ .timezone }}
# {{ .profile }} {{ .enable_workspace }} {{ .enable_ai_tools }} {{ .enable_warp }}
# {{ .ssh_key_name }} {{ .has_age_key }}

GREEN='\033[0;32m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

label() { printf "  ${CYAN}%-14s${NC} %s\n" "$1" "$2"; }
line()  { echo -e "${DIM}──────────────────────────────────────────${NC}"; }

echo ""
echo -e "${GREEN}${BOLD}  Dotfiles v2 — Applied Configuration${NC}"
line
label "Name:" "{{ .name }}"
label "Email:" "{{ .email }}"
label "GitHub:" "{{ .github_user }}"
label "Timezone:" "{{ .timezone }}"
label "Hostname:" "{{ .hostname }}"
label "OS/Arch:" "{{ .os }}/{{ .arch }}"
label "Profile:" "{{ .profile }}"
label "Workspace:" "{{ .enable_workspace }}{{ if .enable_workspace }} ({{ .workspace_path }}){{ end }}"
label "AI Tools:" "{{ .enable_ai_tools }}"
label "Warp:" "{{ .enable_warp }}"
label "SSH Key:" "{{ .ssh_key_name }}"
label "Encryption:" "{{ .has_age_key }}{{ if .has_age_key }} ({{ .age_identity }}){{ end }}"
line
echo ""
echo "  Next steps:"
echo "    1. Restart shell:  exec zsh"
{{ if .has_age_key -}}
echo "    2. Setup secrets:  secrets init"
echo "       Or restore:     secrets restore <backup-dir>"
{{ else -}}
echo "    2. (Optional) Setup encryption:"
echo "       age-keygen -o ~/.config/chezmoi/key.txt"
{{ end -}}
{{ if .enable_ai_tools -}}
echo "    3. Install Claude Code:  npm i -g @anthropic-ai/claude-code"
echo "    4. Authenticate GitHub:  gh auth login"
{{ end -}}
echo ""
echo -e "  ${DIM}Reconfigure anytime: ~/.dotfiles-v2/scripts/reconfigure.sh${NC}"
echo ""
