#!/usr/bin/env bash
{{ if not .enable_workspace -}}
exit 0
{{ end -}}

set -euo pipefail
info() { echo "[+] $*"; }

{{ if and .is_darwin (ne .workspace_gdrive "") -}}
# Google Drive symlink
GDRIVE="{{ .workspace_gdrive }}"
WORKSPACE="{{ .workspace_path }}"
WORKSPACE="${WORKSPACE/#\~/$HOME}"
GDRIVE="${GDRIVE/#\~/$HOME}"

if [ -d "$GDRIVE" ] && [ ! -L "$WORKSPACE" ]; then
  ln -s "$GDRIVE" "$WORKSPACE"
  info "Created $WORKSPACE -> $GDRIVE"
fi
{{ end -}}

WORKSPACE="{{ .workspace_path }}"
WORKSPACE="${WORKSPACE/#\~/$HOME}"

# .brain symlink
if [ -d "$WORKSPACE/vault" ] && [ ! -L "$HOME/.brain" ]; then
  ln -s "$WORKSPACE/vault" "$HOME/.brain"
  info "Created ~/.brain -> vault"
fi

# work <-> vault 상호 참조
[ -d "$WORKSPACE/work" ] && [ ! -L "$WORKSPACE/work/.vault" ] && \
  ln -s ../vault "$WORKSPACE/work/.vault" 2>/dev/null || true
[ -d "$WORKSPACE/vault" ] && [ ! -L "$WORKSPACE/vault/.work" ] && \
  ln -s ../work "$WORKSPACE/vault/.work" 2>/dev/null || true

info "Workspace setup complete"
