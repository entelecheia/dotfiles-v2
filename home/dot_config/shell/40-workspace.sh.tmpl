{{ if .enable_workspace -}}
# workspace 경로
export WORKSPACE="{{ .workspace_path }}"
export WORK="$WORKSPACE/work"
export VAULT="$WORKSPACE/vault"

# 빠른 이동
alias work="cd \$WORK"
alias vault="cd \$VAULT"
alias brain="cd \$VAULT"

# 프로젝트 이동
proj()  { cd "$WORK/projects/${1:-}" 2>/dev/null || echo "Not found: $1"; }
teach() { cd "$WORK/teaching/${1:-}" 2>/dev/null || echo "Not found: $1"; }
{{ end -}}
