# ── Colors ──────────────────────────────────────────────────────────────────
set -g default-terminal "tmux-256color"
set -ga terminal-overrides ",xterm-256color:Tc"

# ── Prefix ───────────────────────────────────────────────────────────────────
unbind C-b
set -g prefix C-a
bind C-a send-prefix

# ── General ──────────────────────────────────────────────────────────────────
set -g default-shell "$SHELL"
set -g history-limit 50000
set -g mouse on
set -g base-index 1
setw -g pane-base-index 1
set -g renumber-windows on
set -sg escape-time 10
set -g focus-events on
set -g repeat-time 600
setw -g aggressive-resize on

# ── Activity monitoring ─────────────────────────────────────────────────────
setw -g monitor-activity on
set -g visual-activity off

# ── Vi mode ──────────────────────────────────────────────────────────────────
setw -g mode-keys vi
bind Enter copy-mode
bind -T copy-mode-vi v send-keys -X begin-selection
bind -T copy-mode-vi y send-keys -X copy-selection-and-cancel
bind -T copy-mode-vi Escape send-keys -X cancel

# ── Windows ─────────────────────────────────────────────────────────────────
bind c new-window -c "#{pane_current_path}"
bind < swap-window -d -t -1
bind > swap-window -d -t +1

# ── Splits ───────────────────────────────────────────────────────────────────
bind | split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"
unbind '"'
unbind %

# ── Pane navigation ──────────────────────────────────────────────────────────
bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R

# ── Pane resize ──────────────────────────────────────────────────────────────
bind -r H resize-pane -L 5
bind -r J resize-pane -D 5
bind -r K resize-pane -U 5
bind -r L resize-pane -R 5

# ── Reload config ────────────────────────────────────────────────────────────
bind r source-file ~/.tmux.conf \; display-message "config reloaded"

# ── Cheatsheet popup ────────────────────────────────────────────────────────
bind / display-popup -w 60 -h 20 -E "cat <<'EOF'\n\
── dotfiles tmux cheatsheet ──\n\
Prefix: C-a\n\
\n\
Session    C-a d detach  C-a s list  C-a $ rename\n\
Window     C-a c new     C-a , rename  C-a n/p next/prev\n\
           C-a < /> swap left/right\n\
Split      C-a | horiz   C-a - vert\n\
Pane       C-a h/j/k/l  navigate\n\
           C-a H/J/K/L  resize\n\
Copy       C-a Enter → v select → y copy → Esc cancel\n\
Mouse      ON (scroll, select, resize)\n\
Reload     C-a r\n\
Help       C-a ? all keys   C-a / this cheatsheet\n\
EOF\n\
read -n 1"

# ── Status bar ───────────────────────────────────────────────────────────────
set -g status on
set -g status-interval 5
set -g status-position bottom
set -g status-style "bg=colour235,fg=colour250"

set -g status-left " #[fg=colour39,bold]#S #[default]"
set -g status-left-length 20

set -g status-right "#[fg=colour250]{{ .Hostname }} #[fg=colour239]| #[fg=colour250]%H:%M "
set -g status-right-length 40

setw -g window-status-format " #I:#W "
setw -g window-status-current-format "#[fg=colour39,bold] #I:#W #[default]"

set -g pane-border-style "fg=colour238"
set -g pane-active-border-style "fg=colour39"
