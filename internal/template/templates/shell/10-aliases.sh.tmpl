# ── Modern CLI replacements ──
command -v eza &>/dev/null && {
  alias ls="eza"
  alias ll="eza -l --git"
  alias la="eza -la --git"
  alias lt="eza --tree --level=2"
}

command -v bat &>/dev/null && alias cat="bat --paging=never"
command -v lazygit &>/dev/null && alias lg="lazygit"

# ── Tmux shortcuts ──
alias ta="tmux attach -t"
alias ts="tmux new-session -s"
alias tl="tmux list-sessions"
alias tk="tmux kill-session -t"
alias td="tmux detach"

# ── Workspace shortcuts (dotfiles/dot) ──
# dot <project>       — launch or resume workspace
# dot list            — show projects & sessions
# dot register <name> — register current dir
# dot layouts         — list available layouts
# dot doctor          — check tool status

# ── Git shortcuts ──
alias gs="git status"
alias gd="git diff"
alias gco="git checkout"
alias gp="git push"
alias gl="git log --oneline -20"

# ── yazi wrapper (change dir on exit) ──
function y() {
  local tmp="$(mktemp -t yazi-cwd.XXXXXX)" cwd
  command yazi "$@" --cwd-file="$tmp"
  IFS= read -r -d '' cwd < "$tmp"
  [ "$cwd" != "$PWD" ] && [ -d "$cwd" ] && builtin cd -- "$cwd"
  rm -f -- "$tmp"
}
