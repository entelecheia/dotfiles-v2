# ── Shell config (순서 보장: 00 -> 50) ──
for f in ~/.config/shell/[0-9]*.sh; do
  [ -r "$f" ] && source "$f"
done

# ── Secrets (암호화 파일, 있을 때만) ──
[ -r ~/.config/shell/90-secrets.sh ] && source ~/.config/shell/90-secrets.sh

# ── Oh My Zsh ──
export ZSH="$HOME/.oh-my-zsh"
export DISABLE_AUTO_UPDATE="true"
ZSH_THEME=""  # starship 사용
plugins=(
  git
  zsh-autosuggestions
  zsh-syntax-highlighting
  zsh-completions
  direnv
)
source "$ZSH/oh-my-zsh.sh"

# ── Tool initialization (oh-my-zsh 이후) ──
source ~/.config/shell/50-tools-init.sh
