# 기본 환경변수
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
export EDITOR="{{ if .IsDarwin }}code --wait{{ else }}nano{{ end }}"
export TZ="{{ .Timezone }}"

# PATH
export PATH="$HOME/.local/bin:$PATH"
{{ if .IsDarwin -}}
export PATH="/opt/homebrew/bin:$PATH"
{{ else -}}
[ -d /home/linuxbrew/.linuxbrew ] && export PATH="/home/linuxbrew/.linuxbrew/bin:$PATH"
{{ end -}}
{{ if .HasCUDA -}}
# CUDA
export CUDA_HOME={{ .CUDAHome }}
export PATH="${CUDA_HOME}/bin:$PATH"
export LD_LIBRARY_PATH="${CUDA_HOME}/lib64:${LD_LIBRARY_PATH:-}"
{{ end -}}

# pnpm: load pnpm-only config from ~/.config/pnpm/npmrc so npm 11+ doesn't warn
# about unknown keys (virtual-store-dir, store-dir, cache-dir). `command pnpm`
# avoids recursion; the function only activates if pnpm is on PATH.
if command -v pnpm >/dev/null 2>&1; then
  pnpm() {
    NPM_CONFIG_USERCONFIG="$HOME/.config/pnpm/npmrc" command pnpm "$@"
  }
fi
