# zoxide
command -v zoxide &>/dev/null && eval "$(zoxide init zsh)"

# starship prompt
command -v starship &>/dev/null && eval "$(starship init zsh)"

# fnm (Node.js)
command -v fnm &>/dev/null && eval "$(fnm env --use-on-cd --shell zsh)"

# direnv
command -v direnv &>/dev/null && eval "$(direnv hook zsh)"

# conda / mamba
if command -v conda &>/dev/null; then
  __dot_conda_hook="$(conda shell.zsh hook 2>/dev/null)" && eval "$__dot_conda_hook"
  unset __dot_conda_hook
elif command -v mamba &>/dev/null; then
  __dot_mamba_hook="$(mamba shell hook --shell zsh 2>/dev/null)" && eval "$__dot_mamba_hook"
  unset __dot_mamba_hook
fi

# AI CLI tools (installer bin dirs; managed here so PATH survives zshrc regeneration)
[ -d "$HOME/.opencode/bin" ] && export PATH="$HOME/.opencode/bin:$PATH"
[ -d "$HOME/.kilo/bin" ] && export PATH="$HOME/.kilo/bin:$PATH"
[ -d "$HOME/.kimi-code/bin" ] && export PATH="$HOME/.kimi-code/bin:$PATH"
